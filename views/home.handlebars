<div class="mt-4">
    <h2 class="fw-bold mb-2">Olá, Rhayssa! 🌸</h2>
    <p class="text-muted mb-4">Aqui está sua biblioteca pessoal 📚</p>

    <!-- Card total de livros -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-white" style="background-color: #9b59b6;">
                <div class="card-body d-flex align-items-center gap-3">
                    <span style="font-size: 2.5rem;">📚</span>
                    <div>
                        <h6 class="card-title mb-1">Total de Livros</h6>
                        <h2 class="fw-bold mb-0">{{total}}</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Últimos livros -->
    <h5 class="fw-bold mb-3">📖 Últimos Livros Adicionados</h5>
    <div class="row g-4 mb-4">
        {{#each ultimos}}
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="fw-bold">{{this.titulo}}</h6>
                    <p class="text-muted mb-1">✍️ {{this.autor}}</p>
                    <p class="text-muted mb-2">🎭 {{this.genero}}</p>
                    <div class="mb-2">{{{estrelas this.estrelas}}}</div>
                    <div>{{{statusBadge this.status}}}</div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>

    <!-- Botões -->
    <div class="mt-2">
        <a href="/livros" class="btn btn-outline-primary me-2">📖 Ver Biblioteca</a>
        <a href="/cadastro" class="btn btn-primary">+ Cadastrar Livro</a>
    </div>
</div>